# Dendrite configuration

# Bulk model (extraction / triage)
BULK_PROVIDER=vllm
BULK_MODEL=Qwen/Qwen3.5-0.8B
BULK_API_URL=http://vllm:8000/v1
BULK_API_KEY=
BULK_MAX_TOKENS=16384

# Synthesis model (cross-validation / report)
# By default uses the same vLLM instance as bulk. To use a different model,
# point SYNTHESIS_API_URL to a second vLLM instance or external API.
SYNTHESIS_PROVIDER=vllm
SYNTHESIS_MODEL=Qwen/Qwen3.5-0.8B
SYNTHESIS_API_URL=http://vllm:8000/v1
SYNTHESIS_API_KEY=
SYNTHESIS_MAX_TOKENS=32768

# GPU (run nvidia-smi --query-gpu=gpu_uuid,name --format=csv to find yours)
GPU_DEVICE=GPU-xxxxxxxx
GPU_MEMORY_UTILIZATION=0.95
KV_CACHE_DTYPE=fp8

# Services
SEARXNG_URL=http://searxng:8080
HIVEMIND_URL=http://hiveminddb:8100

# Research — tree structure
MAX_DEPTH=4                       # max levels deep the tree can grow
MAX_BRANCH_ITERATIONS=5           # search iterations per branch
VERIFICATION_ITERATIONS=2         # iterations for verification/counter branches
QUERIES_PER_ITERATION=4           # search queries generated per iteration

# Research — search width
URLS_PER_ITERATION=20             # max URLs fetched per branch iteration
RESULTS_PER_PROVIDER=10           # max search results per provider per query
MAX_CONCURRENT_FETCHES=50         # parallel page downloads
MAX_CONCURRENT_LLM=100            # parallel LLM calls

# Research — verification depth
VERIFICATION_THRESHOLD=0.6        # confidence below this triggers verification
MIN_INDEPENDENT_SOURCES=2         # sources needed for auto-verify
MAX_CONCURRENT_VERIFICATIONS=3    # parallel cross-validations
VERIFICATION_FETCH_COUNT=3        # pages fetched per verification check

# Research — convergence
MIN_CONVERGENCE_ITERATIONS=2      # min iterations before convergence allowed
DIMINISHING_RETURNS_THRESHOLD=0.10  # new/total claims ratio to stop
COVERAGE_TARGET=0.85              # LLM coverage score to stop
