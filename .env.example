# Dendrite configuration

# Bulk model (extraction / triage)
BULK_PROVIDER=vllm
BULK_MODEL=Qwen/Qwen3.5-0.8B
BULK_API_URL=http://vllm:8000/v1
BULK_API_KEY=
BULK_MAX_TOKENS=16384

# Synthesis model (cross-validation / report)
SYNTHESIS_PROVIDER=vllm
SYNTHESIS_MODEL=Qwen/Qwen3.5-9B-GPTQ-Int4
SYNTHESIS_API_URL=http://vllm:8000/v1
SYNTHESIS_API_KEY=
SYNTHESIS_MAX_TOKENS=32768

# GPU (run nvidia-smi --query-gpu=gpu_uuid,name --format=csv to find yours)
GPU_DEVICE=GPU-xxxxxxxx
GPU_MEMORY_UTILIZATION=0.95
KV_CACHE_DTYPE=fp8

# Services
SEARXNG_URL=http://searxng:8080
HIVEMIND_URL=http://hiveminddb:8100

# Research defaults
MAX_DEPTH=4
MAX_BRANCH_ITERATIONS=5
MAX_CONCURRENT_LLM=100
MAX_CONCURRENT_FETCHES=50
VERIFICATION_THRESHOLD=0.6
MIN_INDEPENDENT_SOURCES=2
